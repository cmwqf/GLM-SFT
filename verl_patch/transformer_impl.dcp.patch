+    def _build_fsdp_module_dcp(self, module, param_dtype, reduce_dtype):
+        """FSDP2 fully_shard on a meta module, then stream weights per-rank from a DCP
+        checkpoint (torch.distributed.checkpoint). Peak per-rank memory ~ model/world_size:
+        no rank holds the full model, no rank0->all broadcast. Produces an FSDP2 module.
+
+        The DCP checkpoint (scripts/convert_hf_to_dcp.py) is keyed by the model's *fused*
+        param names and also carries the (few, tiny) non-persistent buffers (rotary
+        inv_freq), so nothing needs recomputation on the training side.
+        """
+        import torch.distributed.checkpoint as dcp
+        from torch.distributed.checkpoint.state_dict import get_model_state_dict, set_model_state_dict
+
+        ckpt_path = os.environ["VERL_DCP_CKPT_PATH"].strip()
+
+        offload_policy = None
+        if self.engine_config.offload_policy or self.engine_config.forward_only:
+            self._is_offload_param = False
+            self._is_offload_optimizer = False
+            offload_policy = CPUOffloadPolicy(pin_memory=True)
+            self._uses_fsdp2_cpu_offload_policy = True
+
+        mp_policy = MixedPrecisionPolicy(param_dtype=param_dtype, reduce_dtype=reduce_dtype, cast_forward_inputs=True)
+        fsdp_kwargs = {
+            "mesh": self.device_mesh,
+            "mp_policy": mp_policy,
+            "offload_policy": offload_policy,
+            "reshard_after_forward": self.engine_config.reshard_after_forward,
+        }
+
+        # 1) shard the meta model -> params become DTensors (still meta)
+        apply_fsdp2(module, fsdp_kwargs, self.engine_config)
+
+        # 2) materialize each rank's LOCAL shard (empty storage), incl. buffers
+        module.to_empty(device=get_device_id())
+
+        # 3) stream weights: DCP reads only each rank's shard and reshards from the
+        #    single-process (world_size-agnostic) checkpoint into the local DTensors.
+        msd = get_model_state_dict(module)  # params + persistent buffers (sharded DTensors)
+        extra_buffers = {n: b for n, b in module.named_buffers() if n not in msd}  # non-persistent
+        if self.rank == 0:
+            print(f"[DCP] loading sharded checkpoint from {ckpt_path} "
+                  f"({len(msd)} sharded tensors + {len(extra_buffers)} buffers)", flush=True)
+        dcp.load({**msd, **extra_buffers}, checkpoint_id=ckpt_path)  # in-place fill (extra are model refs)
+        set_model_state_dict(module, msd)  # write back model-managed (sharded) tensors
+        torch.distributed.barrier()
+        log_gpu_memory_usage("After DCP sharded load", logger=logger)
+
+        return module
+
